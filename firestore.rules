rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Self-registration always creates a "client" role document for
      // the signed-in user. Staff accounts are created manually
      // (e.g. via the Firebase Console or Admin SDK), which bypasses
      // these rules.
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.role == "client";

      // Users can update their own profile but cannot change their
      // own role (prevents client -> staff self-escalation).
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role;

      allow delete: if false;
    }

    match /requests/{requestId} {
      // Clients can read their own requests; staff can read all of them
      // (checked via their own users/{uid} doc, which is trusted since
      // role can't be self-escalated - see the rule above).
      allow read: if request.auth != null
        && (resource.data.clientId == request.auth.uid
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "staff");

      // Clients can only create requests attributed to themselves, and
      // only in the initial "submitted" state.
      allow create: if request.auth != null
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.status == "submitted";

      // No client-side status updates yet - that lands with the staff
      // dashboard.
      allow update, delete: if false;
    }
  }
}
